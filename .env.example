# =============================================
# FINAGENT — ENVIRONMENT VARIABLES
# Copy this to .env.local and fill in values
# =============================================

# ----- AUTH0 (Required) -----
# Get these from auth0.com > Applications > Your App > Settings
AUTH0_SECRET='use-openssl-rand-base64-32-to-generate'
AUTH0_BASE_URL='http://localhost:3000'
AUTH0_ISSUER_BASE_URL='https://YOUR_TENANT.auth0.com'
AUTH0_CLIENT_ID='your_client_id_here'
AUTH0_CLIENT_SECRET='your_client_secret_here'

# Auth0 Management API (for Token Vault operations)
# auth0.com > Applications > APIs > Auth0 Management API > Test
AUTH0_MGMT_CLIENT_ID='your_mgmt_client_id'
AUTH0_MGMT_CLIENT_SECRET='your_mgmt_client_secret'
AUTH0_MGMT_AUDIENCE='https://YOUR_TENANT.auth0.com/api/v2/'

# Auth0 Token Vault — Connected Accounts API
# Enabled in: auth0.com > AI Agents > Token Vault
AUTH0_TOKEN_VAULT_AUDIENCE='https://YOUR_TENANT.auth0.com/token-vault'

# Auth0 CIBA (for step-up approval)
# Enabled in: auth0.com > Applications > Your App > Advanced > Grant Types
AUTH0_CIBA_BINDING_MESSAGE_PREFIX='FinAgent'

# ----- SUPABASE (Required) -----
# Get from: supabase.com > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL='https://your-project.supabase.co'
NEXT_PUBLIC_SUPABASE_ANON_KEY='your_anon_key_here'
SUPABASE_SERVICE_ROLE_KEY='your_service_role_key_here'

# ----- ANTHROPIC (Required) -----
# Get from: console.anthropic.com > API Keys
ANTHROPIC_API_KEY='sk-ant-your-key-here'

# ----- MONO CONNECT (Data source) -----
# Get from: app.mono.co > Developer > API Keys
MONO_SECRET_KEY='live_sk_your_key'
MONO_PUBLIC_KEY='live_pk_your_key'
# Use 'test' for sandbox mode during development
MONO_ENV='test'

# ----- OPAY (Data source) -----
OPAY_MERCHANT_ID='your_merchant_id'
OPAY_PUBLIC_KEY='your_public_key'
OPAY_PRIVATE_KEY='your_private_key'
# Use sandbox: https://sandbox.opayweb.com
OPAY_BASE_URL='https://sandbox.opayweb.com'

# ----- REMITA (Data source) -----
REMITA_API_KEY='your_remita_api_key'
REMITA_BASE_URL='https://remitademo.net/remita'

# ----- APP CONFIG -----
NEXT_PUBLIC_APP_NAME='FinAgent'
NEXT_PUBLIC_APP_URL='http://localhost:3000'
NODE_ENV='development'
